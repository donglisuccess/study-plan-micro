.plans-page {
  min-height: 100vh;
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
  background: #f3f7fb;
}

.plans-header {
  padding: 40rpx 30rpx 34rpx;
  background: linear-gradient(135deg, #2f80ed 0%, #1f66bf 100%);
  color: #ffffff;
}

.plans-title {
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 900;
}

.plans-subtitle {
  margin-top: 8rpx;
  color: #d9eaff;
  font-size: 25rpx;
}

.plans-stats {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.14);
}

.stat-item {
  flex: 1;
}

.stat-value {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
}

.stat-label {
  margin-top: 2rpx;
  color: #d9eaff;
  font-size: 22rpx;
}

.stat-divider {
  width: 1rpx;
  height: 54rpx;
  margin: 0 30rpx;
  background: rgba(255, 255, 255, 0.24);
}

.subject-filters {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.subject-filters-inner {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 30rpx 8rpx;
}

.subject-filter {
  min-width: 110rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border: 2rpx solid #d9e3ef;
  border-radius: 99rpx;
  background: #ffffff;
  color: #52657d;
  font-size: 25rpx;
  line-height: 60rpx;
  text-align: center;
}

.subject-filter.is-active {
  border-color: #2f80ed;
  background: #eaf4ff;
  color: #1f66bf;
  font-weight: 800;
}

.swipe-guide {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 14rpx 30rpx 0;
  padding: 18rpx 22rpx;
  border: 2rpx solid #d6e7fb;
  border-radius: 14rpx;
  background: #edf6ff;
}

.swipe-guide-gesture {
  position: relative;
  flex: 0 0 62rpx;
  width: 62rpx;
  height: 48rpx;
  overflow: hidden;
}

.gesture-hand {
  position: absolute;
  right: 3rpx;
  top: 6rpx;
  width: 26rpx;
  height: 34rpx;
  border: 4rpx solid #2f80ed;
  border-radius: 13rpx 13rpx 10rpx 10rpx;
  animation: swipe-guide-move 1.8s ease-in-out infinite;
}

.gesture-hand::before {
  content: "";
  position: absolute;
  left: 7rpx;
  top: -13rpx;
  width: 8rpx;
  height: 17rpx;
  border: 4rpx solid #2f80ed;
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
  background: #edf6ff;
}

.gesture-arrow {
  position: absolute;
  left: 3rpx;
  top: 21rpx;
  width: 25rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #2f80ed;
}

.gesture-arrow::before {
  content: "";
  position: absolute;
  left: 0;
  top: -6rpx;
  width: 12rpx;
  height: 12rpx;
  border-left: 4rpx solid #2f80ed;
  border-bottom: 4rpx solid #2f80ed;
  transform: rotate(45deg);
}

.swipe-guide-copy {
  flex: 1;
  min-width: 0;
}

.swipe-guide-close {
  position: relative;
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(47, 128, 237, 0.08);
}

.close-line {
  position: absolute;
  left: 14rpx;
  top: 22rpx;
  width: 20rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: #7189a3;
}

.close-line-a {
  transform: rotate(45deg);
}

.close-line-b {
  transform: rotate(-45deg);
}

.swipe-guide-title {
  color: #215f9f;
  font-size: 25rpx;
  line-height: 1.35;
  font-weight: 800;
}

.swipe-guide-desc {
  margin-top: 3rpx;
  color: #7189a3;
  font-size: 21rpx;
  line-height: 1.35;
}

@keyframes swipe-guide-move {
  0%,
  25% {
    opacity: 1;
    transform: translateX(0);
  }

  65% {
    opacity: 1;
    transform: translateX(-22rpx);
  }

  85%,
  100% {
    opacity: 0.3;
    transform: translateX(-22rpx);
  }
}

.plans-list {
  padding: 18rpx 30rpx 0;
}

.swipe-plan-item {
  position: relative;
  overflow: hidden;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  background: #ef5350;
  box-shadow: 0 8rpx 24rpx rgba(36, 64, 102, 0.05);
}

.swipe-card-content {
  position: relative;
  z-index: 2;
  width: 100%;
  background: #ffffff;
  transition: transform 0.24s cubic-bezier(0.2, 0.75, 0.25, 1);
  will-change: transform;
}

.swipe-plan-item.is-dragging .swipe-card-content {
  transition: none;
}

.plan-delete-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1;
  width: 144rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #ff6b68 0%, #e84545 100%);
  color: #ffffff;
  font-size: 25rpx;
  line-height: 1;
  font-weight: 800;
}

.delete-action-icon {
  position: relative;
  width: 34rpx;
  height: 38rpx;
}

.delete-lid {
  position: absolute;
  left: 3rpx;
  top: 3rpx;
  width: 28rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #ffffff;
}

.delete-lid::before {
  content: "";
  position: absolute;
  left: 9rpx;
  top: -6rpx;
  width: 10rpx;
  height: 6rpx;
  border: 3rpx solid #ffffff;
  border-bottom: none;
  border-radius: 5rpx 5rpx 0 0;
}

.delete-bin {
  position: absolute;
  left: 6rpx;
  top: 11rpx;
  width: 22rpx;
  height: 25rpx;
  border: 3rpx solid #ffffff;
  border-top: none;
  border-radius: 0 0 5rpx 5rpx;
}

.delete-bin::before,
.delete-bin::after {
  content: "";
  position: absolute;
  top: 4rpx;
  bottom: 4rpx;
  width: 3rpx;
  border-radius: 3rpx;
  background: rgba(255, 255, 255, 0.9);
}

.delete-bin::before {
  left: 5rpx;
}

.delete-bin::after {
  right: 5rpx;
}

.plan-history-card {
  padding: 26rpx 26rpx 22rpx;
  border: 2rpx solid #dfe8f2;
  border-radius: 16rpx;
  background: #ffffff;
}

.plan-history-card.is-completed {
  border-color: #ccebdd;
  background: #fbfefc;
}

.history-card-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.subject-mark {
  flex: 0 0 68rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eaf4ff;
  color: #2f80ed;
  font-size: 30rpx;
  font-weight: 900;
}

.is-completed .subject-mark {
  background: #e4f6ed;
  color: #269d6a;
}

.history-main {
  flex: 1;
  min-width: 0;
}

.history-title {
  color: #071832;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 900;
}

.history-meta {
  margin-top: 5rpx;
  overflow: hidden;
  color: #718198;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-arrow {
  color: #8293a8;
  font-size: 46rpx;
  line-height: 1;
}

.history-progress-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  color: #66788f;
  font-size: 23rpx;
}

.history-progress-value {
  color: #2f80ed;
  font-weight: 800;
}

.is-completed .history-progress-value {
  color: #269d6a;
}

.history-progress-track {
  height: 12rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 99rpx;
  background: #e4edf7;
}

.history-progress-fill {
  height: 100%;
  border-radius: 99rpx;
  background: linear-gradient(90deg, #2f80ed 0%, #37b982 100%);
}

.history-next {
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  border-radius: 10rpx;
  background: #f4f7fb;
  color: #41546b;
  font-size: 24rpx;
  line-height: 1.5;
}

.history-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.history-time {
  color: #94a2b4;
  font-size: 21rpx;
}

.history-action {
  color: #2f80ed;
  font-size: 24rpx;
  font-weight: 800;
}

.is-completed .history-action {
  color: #269d6a;
}

.empty-plans {
  padding: 150rpx 56rpx 60rpx;
  text-align: center;
}

.empty-icon {
  width: 130rpx;
  height: 150rpx;
  margin: 0 auto;
  padding-top: 48rpx;
  border: 5rpx solid #aac8e9;
  border-radius: 18rpx;
  background: #ffffff;
}

.empty-line {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 99rpx;
  background: #c5dbf1;
}

.empty-line.is-short {
  width: 50rpx;
}

.empty-title {
  margin-top: 34rpx;
  color: #071832;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  color: #75869c;
  font-size: 25rpx;
  line-height: 1.6;
}

.create-plan-button {
  width: 320rpx;
  height: 82rpx;
  margin: 34rpx auto 0;
  border-radius: 16rpx;
  background: #2f80ed;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 82rpx;
  font-weight: 800;
}
