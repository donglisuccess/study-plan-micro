.plan-page {
  padding: 32rpx 30rpx calc(170rpx + env(safe-area-inset-bottom));
  background: var(--page-background);
}

.summary-card {
  position: relative;
  overflow: hidden;
  padding: 38rpx 38rpx 42rpx;
  border-radius: 28rpx;
  background: linear-gradient(128deg, #5898fd 0%, #45c4ee 58%, #4fd8dc 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(58, 120, 242, 0.16);
}

.summary-bg {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.summary-bg-a {
  width: 180rpx;
  height: 180rpx;
  right: -36rpx;
  top: -48rpx;
}

.summary-bg-b {
  width: 132rpx;
  height: 132rpx;
  right: 70rpx;
  bottom: -54rpx;
}

.summary-kicker,
.summary-title,
.summary-grid {
  position: relative;
  z-index: 1;
}

.summary-kicker {
  color: #cfe4ff;
  font-size: 27rpx;
}

.summary-title {
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 600;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  margin-top: 32rpx;
}

.summary-item {
  min-height: 112rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.17);
}

.summary-label {
  color: #d7eaff;
  font-size: 25rpx;
}

.summary-value {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 31rpx;
  line-height: 1.25;
  font-weight: 600;
}

.explain-card {
  display: flex;
  gap: 20rpx;
  margin-top: 26rpx;
  padding: 26rpx 28rpx;
  border: 2rpx solid #ffe0c8;
  border-radius: 22rpx;
  background: #fff8f2;
  color: #7a421d;
}

.explain-icon {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffe6c4;
  color: #e96d2d;
  font-weight: 600;
}

.explain-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.75;
}

.progress-overview {
  margin-top: 26rpx;
  padding: 28rpx 30rpx;
  border: 2rpx solid #dce8f5;
  border-radius: 16rpx;
  background: #ffffff;
}

.progress-overview.is-complete {
  border-color: #d7e2f2;
  background: #f8faff;
}

.progress-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.progress-label {
  color: #999999;
  font-size: 24rpx;
}

.progress-count {
  margin-top: 2rpx;
  color: #333333;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 600;
}

.progress-percent {
  color: #3a78f2;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 600;
}

.is-complete .progress-percent {
  color: #3a78f2;
}

.plan-progress-track {
  height: 14rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 99rpx;
  background: #e5edf7;
}

.plan-progress-fill {
  height: 100%;
  border-radius: 99rpx;
  background: linear-gradient(90deg, #3a78f2 0%, #6aa5ff 100%);
  transition: width 0.25s ease;
}

.next-task-text {
  margin-top: 18rpx;
  color: #666666;
  font-size: 25rpx;
  line-height: 1.45;
}

.list-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 38rpx;
}

.list-heading .section-heading {
  margin: 0;
}

.week-hint {
  color: #999999;
  font-size: 23rpx;
}

.week-tabs {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.week-tabs-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 0 8rpx;
}

.week-tab {
  width: 186rpx;
  min-height: 92rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid #dbe5f1;
  border-radius: 14rpx;
  background: #ffffff;
  color: #666666;
}

.week-tab.is-active {
  border-color: #3a78f2;
  background: #edf3ff;
  color: #3a78f2;
  box-shadow: 0 8rpx 18rpx rgba(58, 120, 242, 0.1);
}

.week-tab.is-complete {
  border-color: #dfe5ec;
}

.week-tab.is-active.is-complete {
  border-color: #3a78f2;
  background: #edf3ff;
  color: #3a78f2;
}

.week-tab-title {
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 600;
}

.week-tab-meta {
  margin-top: 5rpx;
  color: #999999;
  font-size: 21rpx;
}

.week-tab.is-active .week-tab-meta {
  color: currentColor;
  opacity: 0.76;
}

.day-list {
  margin-top: 20rpx;
}

.day-card {
  overflow: hidden;
  margin-bottom: 18rpx;
  border: 2rpx solid #eeeeee;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(32, 33, 49, 0.04);
  transition:
    border-color 0.28s ease,
    box-shadow 0.28s ease,
    background-color 0.28s ease;
}

.day-card.is-expanded {
  border-color: #c9d9fb;
  box-shadow: 0 12rpx 28rpx rgba(58, 120, 242, 0.09);
}

.day-card.is-completed {
  border-color: #e2e7ed;
  background: #fafbfc;
}

.day-card.is-completed.is-expanded {
  border-color: #ccd9ec;
  box-shadow: 0 12rpx 28rpx rgba(58, 120, 242, 0.07);
}

.day-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 130rpx;
  padding: 24rpx 24rpx 20rpx;
}

.day-number {
  flex: 0 0 68rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf3ff;
  color: #3a78f2;
  font-size: 30rpx;
  font-weight: 600;
}

.is-completed .day-number {
  background: #edf3ff;
  color: #3a78f2;
}

.day-main {
  flex: 1;
  min-width: 0;
}

.day-title {
  color: #333333;
  font-size: 31rpx;
  line-height: 1.2;
  font-weight: 600;
}

.day-theme {
  display: block;
  max-width: 100%;
  margin-top: 6rpx;
  overflow: hidden;
  color: #333333;
  font-size: 26rpx;
  line-height: 1.35;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition:
    color 0.25s ease,
    opacity 0.25s ease;
}

.day-summary {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  color: #999999;
  font-size: 22rpx;
}

.summary-separator {
  margin: 0 10rpx;
}

.check-circle {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 4rpx solid #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 600;
  transition:
    border-color 0.22s ease,
    background-color 0.22s ease,
    transform 0.22s ease;
}

.complete-control {
  flex: 0 0 140rpx;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 99rpx;
  background: #f2f6fb;
  color: #666666;
  font-size: 23rpx;
  font-weight: 700;
  transition:
    color 0.22s ease,
    background-color 0.22s ease,
    transform 0.16s ease;
}

.complete-control:active {
  transform: scale(0.96);
}

.complete-control.is-checked {
  background: #edf3ff;
  color: #3a78f2;
}

.complete-control.is-checked .check-circle {
  border-color: #3a78f2;
  background: #3a78f2;
  transform: scale(1.06);
}

.day-details-wrap {
  height: 0;
  overflow: hidden;
  opacity: 0;
  transform: translateY(-12rpx);
  transition:
    height 0.38s cubic-bezier(0.4, 0, 0.2, 1),
    opacity 0.24s ease,
    transform 0.32s ease;
  will-change: height, opacity, transform;
}

.day-details-wrap.is-open {
  opacity: 1;
  transform: translateY(0);
}

.day-details {
  padding: 4rpx 24rpx 24rpx;
  border-top: 1rpx solid #eeeeee;
}

.task-list {
  padding-top: 10rpx;
}

.task-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2f7;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
  transition:
    color 0.3s ease,
    opacity 0.3s ease;
}

.task-row:last-child {
  border-bottom: none;
}

.task-index {
  flex: 0 0 38rpx;
  width: 38rpx;
  height: 38rpx;
  margin-top: 3rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf3ff;
  color: #3a78f2;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 600;
  transition:
    color 0.3s ease,
    background-color 0.3s ease,
    transform 0.3s ease;
}

.task-text {
  flex: 1;
  min-width: 0;
  transition:
    color 0.3s ease,
    opacity 0.3s ease;
}

.task-label {
  display: inline;
  max-width: 100%;
  transition:
    color 0.3s ease,
    opacity 0.3s ease;
}

.task-index-check {
  display: none;
}

.is-completed .task-row {
  color: #999999;
}

.is-completed .task-index {
  background: #edf3ff;
  color: #3a78f2;
  transform: scale(0.94);
}

.is-completed .task-index-number {
  display: none;
}

.is-completed .task-index-check {
  display: inline;
}

.is-completed .task-text {
  color: #999999;
}

.is-completed .task-label {
  text-decoration-line: line-through;
  text-decoration-color: #a5acb5;
  text-decoration-thickness: 2rpx;
}

.is-completed .day-theme {
  color: #888888;
  opacity: 0.78;
}

.is-completed .day-summary {
  color: #aaaaaa;
}

.day-tip {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-left: 6rpx solid #ffae63;
  border-radius: 10rpx;
  background: #fff8f1;
  transition:
    border-color 0.3s ease,
    background-color 0.3s ease,
    opacity 0.3s ease;
}

.tip-label {
  color: #c65e22;
  font-size: 23rpx;
  font-weight: 600;
}

.tip-text {
  margin-top: 4rpx;
  color: #6f523e;
  font-size: 25rpx;
  line-height: 1.55;
}

.is-completed .day-tip {
  border-left-color: #cfd7e2;
  background: #f6f7f9;
  opacity: 0.72;
}

.is-completed .tip-label,
.is-completed .tip-text {
  color: #8d96a3;
}

.expand-handle {
  height: 58rpx;
  border-top: 1rpx solid #edf2f7;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #666666;
  font-size: 23rpx;
  background: #fafbfd;
  transition:
    color 0.25s ease,
    background-color 0.25s ease;
}

.expand-handle.is-open {
  color: #3a78f2;
  background: #f7f9fe;
}

.expand-arrow {
  width: 13rpx;
  height: 13rpx;
  margin-top: -6rpx;
  border-right: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(45deg);
  transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
}

.expand-handle.is-open .expand-arrow {
  margin-top: 6rpx;
  transform: rotate(225deg);
}

.is-completed .expand-handle {
  background: #f7f8fa;
}

.plan-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 14rpx 22rpx calc(14rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e4ebf4;
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(7, 24, 50, 0.07);
  transform: translate3d(0, 0, 0);
  backface-visibility: hidden;
}

.plan-action-inner {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
}

.utility-action-button {
  flex: 0 0 112rpx;
  width: 112rpx;
  height: 92rpx;
  border: 2rpx solid #e0e7f0;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  background: #f8fafc;
  color: #666666;
}

.utility-action-label {
  font-size: 21rpx;
  line-height: 1;
  font-weight: 700;
}

.refresh-action-icon {
  position: relative;
  width: 31rpx;
  height: 31rpx;
  border: 4rpx solid #63758c;
  border-right-color: transparent;
  border-radius: 50%;
  transform: rotate(-18deg);
  margin-top: -2rpx;
}

.refresh-action-icon::after {
  content: '';
  position: absolute;
  right: -6rpx;
  top: -5rpx;
  width: 0;
  height: 0;
  border-left: 8rpx solid #63758c;
  border-top: 6rpx solid transparent;
  border-bottom: 6rpx solid transparent;
  transform: rotate(18deg);
}

.feedback-action-icon {
  position: relative;
  width: 34rpx;
  height: 27rpx;
  border: 4rpx solid #63758c;
  border-radius: 10rpx;
  margin-top: -2rpx;
}

.feedback-action-icon::after {
  content: '';
  position: absolute;
  left: 5rpx;
  bottom: -9rpx;
  width: 10rpx;
  height: 10rpx;
  border-left: 4rpx solid #63758c;
  border-bottom: 4rpx solid #63758c;
  background: #f8fafc;
  transform: skewY(-36deg);
}

.poster-action-button {
  flex: 1;
  min-width: 0;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  background: #3a78f2;
  color: #ffffff;
  font-size: 29rpx;
  line-height: 1.2;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(58, 120, 242, 0.18);
}

.share-action-icon {
  position: relative;
  flex: 0 0 38rpx;
  width: 38rpx;
  height: 38rpx;
}

.share-action-node {
  position: absolute;
  z-index: 2;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  background: #3a78f2;
}

.share-action-node-a {
  left: 0;
  top: 13rpx;
}

.share-action-node-b {
  right: 0;
  top: 0;
}

.share-action-node-c {
  right: 0;
  bottom: 0;
}

.share-action-line {
  position: absolute;
  z-index: 1;
  left: 9rpx;
  width: 24rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: #ffffff;
  transform-origin: left center;
}

.share-action-line-a {
  top: 16rpx;
  transform: rotate(-28deg);
}

.share-action-line-b {
  top: 21rpx;
  transform: rotate(28deg);
}

.completion-celebration {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 44rpx;
  pointer-events: none;
  background: rgba(31, 50, 76, 0.12);
  animation: celebration-mask-in 0.26s ease both;
}

.completion-card {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 610rpx;
  padding: 52rpx 42rpx 44rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.98);
  text-align: center;
  box-shadow: 0 28rpx 80rpx rgba(31, 55, 86, 0.2);
  animation: completion-card-in 0.48s cubic-bezier(0.2, 0.8, 0.2, 1.08) both;
}

.completion-icon {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto 26rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf3ff;
}

.completion-icon::before,
.completion-icon::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(58, 120, 242, 0.2);
  animation: completion-ring 1.5s ease-out infinite;
}

.completion-icon::before {
  width: 118rpx;
  height: 118rpx;
}

.completion-icon::after {
  width: 138rpx;
  height: 138rpx;
  animation-delay: 0.35s;
}

.completion-check {
  position: relative;
  z-index: 2;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #3a78f2;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(58, 120, 242, 0.24);
}

.completion-kicker {
  color: #3a78f2;
  font-size: 21rpx;
  line-height: 1.3;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.completion-title {
  margin-top: 15rpx;
  color: #333333;
  font-size: 36rpx;
  line-height: 1.45;
  font-weight: 600;
}

.completion-description {
  margin-top: 15rpx;
  color: #888888;
  font-size: 24rpx;
  line-height: 1.65;
}

.confetti {
  position: absolute;
  z-index: 3;
  top: 18%;
  width: 13rpx;
  height: 30rpx;
  border-radius: 3rpx;
  opacity: 0;
  animation: confetti-fall 2.2s cubic-bezier(0.16, 0.7, 0.3, 1) both;
}

.confetti-a {
  left: 12%;
  background: #3a78f2;
  animation-delay: 0.04s;
}

.confetti-b {
  left: 21%;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ffd166;
  animation-delay: 0.18s;
}

.confetti-c {
  left: 31%;
  background: #ff8c78;
  animation-delay: 0.08s;
}

.confetti-d {
  left: 41%;
  width: 11rpx;
  height: 25rpx;
  background: #7dc8f5;
  animation-delay: 0.28s;
}

.confetti-e {
  left: 49%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #8fd6b6;
  animation-delay: 0.1s;
}

.confetti-f {
  left: 58%;
  background: #f3a95f;
  animation-delay: 0.23s;
}

.confetti-g {
  left: 68%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #779cf6;
  animation-delay: 0.02s;
}

.confetti-h {
  left: 77%;
  background: #ff8097;
  animation-delay: 0.31s;
}

.confetti-i {
  left: 86%;
  width: 11rpx;
  height: 24rpx;
  background: #65c8c0;
  animation-delay: 0.14s;
}

.confetti-j {
  left: 92%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ffd166;
  animation-delay: 0.36s;
}

@keyframes celebration-mask-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes completion-card-in {
  from {
    opacity: 0;
    transform: translateY(34rpx) scale(0.92);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes completion-ring {
  0% {
    opacity: 0.65;
    transform: scale(0.72);
  }

  100% {
    opacity: 0;
    transform: scale(1.2);
  }
}

@keyframes confetti-fall {
  0% {
    opacity: 0;
    transform: translate3d(0, -70rpx, 0) rotate(0deg);
  }

  12% {
    opacity: 1;
  }

  65% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translate3d(24rpx, 760rpx, 0) rotate(540deg);
  }
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  background: rgba(7, 24, 50, 0.48);
}

.feedback-modal {
  width: 100%;
  padding: 34rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 30rpx 30rpx 0 0;
  background: #ffffff;
}

.modal-title {
  text-align: center;
  color: #333333;
  font-size: 34rpx;
  font-weight: 600;
}

.feedback-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 30rpx;
}

.feedback-tag {
  min-height: 62rpx;
  padding: 12rpx 22rpx;
  border: 2rpx solid #dbe4ef;
  border-radius: 999rpx;
  color: #666666;
  background: #ffffff;
  font-size: 27rpx;
}

