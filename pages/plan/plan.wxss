.plan-page {
  padding: 32rpx 30rpx calc(220rpx + env(safe-area-inset-bottom));
  background: #f3f7fb;
}

.summary-card {
  position: relative;
  overflow: hidden;
  padding: 38rpx 38rpx 42rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2f80ed 0%, #1f62b5 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(47, 128, 237, 0.18);
}

.summary-bg {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.summary-bg-a {
  width: 180rpx;
  height: 180rpx;
  right: -36rpx;
  top: -48rpx;
}

.summary-bg-b {
  width: 132rpx;
  height: 132rpx;
  right: 70rpx;
  bottom: -54rpx;
}

.summary-kicker,
.summary-title,
.summary-grid {
  position: relative;
  z-index: 1;
}

.summary-kicker {
  color: #cfe4ff;
  font-size: 27rpx;
}

.summary-title {
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 900;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  margin-top: 32rpx;
}

.summary-item {
  min-height: 112rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.17);
}

.summary-label {
  color: #d7eaff;
  font-size: 25rpx;
}

.summary-value {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 31rpx;
  line-height: 1.25;
  font-weight: 900;
}

.explain-card {
  display: flex;
  gap: 20rpx;
  margin-top: 26rpx;
  padding: 26rpx 28rpx;
  border: 2rpx solid #ffe0c8;
  border-radius: 22rpx;
  background: #fff8f2;
  color: #7a421d;
}

.explain-icon {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffe6c4;
  color: #e96d2d;
  font-weight: 900;
}

.explain-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.75;
}

.list-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
}

.list-heading .section-heading {
  margin: 0;
}

.completion-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #eaf4ff;
  color: #1f66bf;
  font-size: 25rpx;
  font-weight: 700;
}

.day-list {
  margin-top: 22rpx;
}

.day-card {
  margin-bottom: 22rpx;
  padding: 30rpx 30rpx 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(36, 64, 102, 0.07);
}

.day-top {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.day-number {
  width: 70rpx;
  height: 70rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e5f1ff;
  color: #2f80ed;
  font-size: 30rpx;
  font-weight: 900;
}

.day-main {
  flex: 1;
  min-width: 0;
}

.day-title {
  color: #071832;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
}

.day-theme {
  display: inline-flex;
  max-width: 100%;
  margin-top: 10rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  background: #fff0e7;
  color: #e96d2d;
  font-size: 25rpx;
  font-weight: 700;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 5rpx solid #c9d6e8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.check-circle.is-checked {
  border-color: #2f80ed;
  background: #2f80ed;
}

.task-list {
  margin: 24rpx 0 0 92rpx;
}

.task-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 12rpx;
  color: #26384f;
  font-size: 28rpx;
  line-height: 1.55;
}

.task-dot {
  flex: 0 0 10rpx;
  width: 10rpx;
  height: 10rpx;
  margin-top: 17rpx;
  border-radius: 50%;
  background: #2f80ed;
}

.task-text {
  flex: 1;
}

.day-meta {
  margin: 22rpx 0 0 92rpx;
  color: #65758d;
  font-size: 25rpx;
}

.day-tip {
  margin: 16rpx 0 0 92rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f5f8fc;
  color: #5f7088;
  font-size: 25rpx;
}

.plan-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.poster-button {
  height: 92rpx;
}

.secondary-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.secondary-button {
  width: 100%;
  height: 82rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  background: rgba(7, 24, 50, 0.48);
}

.feedback-modal {
  width: 100%;
  padding: 34rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 30rpx 30rpx 0 0;
  background: #ffffff;
}

.modal-title {
  text-align: center;
  color: #071832;
  font-size: 34rpx;
  font-weight: 900;
}

.feedback-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 30rpx;
}

.feedback-tag {
  min-height: 62rpx;
  padding: 12rpx 22rpx;
  border: 2rpx solid #dbe4ef;
  border-radius: 999rpx;
  color: #42546b;
  background: #ffffff;
  font-size: 27rpx;
}

.feedback-tag.is-active {
  border-color: #2f80ed;
  color: #1f66bf;
  background: #eaf4ff;
  font-weight: 800;
}

.feedback-input {
  width: 100%;
  min-height: 170rpx;
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f5f8fc;
  color: #071832;
  font-size: 28rpx;
  line-height: 1.5;
}

.submit-feedback {
  margin-top: 24rpx;
  height: 88rpx;
}
