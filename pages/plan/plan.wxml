<view class="page plan-page" wx:if="{{plan}}">
  <view class="summary-card">
    <view class="summary-bg summary-bg-a"></view>
    <view class="summary-bg summary-bg-b"></view>
    <view class="summary-kicker">你的专属计划</view>
    <view class="summary-title">{{plan.grade}} · {{plan.subject}}</view>
    <view class="summary-grid">
      <view class="summary-item">
        <view class="summary-label">学习目标</view>
        <view class="summary-value">{{plan.goal}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">计划周期</view>
        <view class="summary-value">{{plan.days}} 天</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">每日时长</view>
        <view class="summary-value">{{plan.dailyTime}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">当前基础</view>
        <view class="summary-value">{{plan.level}}</view>
      </view>
    </view>
  </view>

  <view class="explain-card">
    <view class="explain-icon">!</view>
    <view class="explain-text">{{plan.summary}}</view>
  </view>

  <view class="progress-overview {{allCompleted ? 'is-complete' : ''}}">
    <view class="progress-heading">
      <view>
        <view class="progress-label">计划完成度</view>
        <view class="progress-count">{{completedCount}} / {{plan.days}} 天</view>
      </view>
      <view class="progress-percent">{{progressPercent}}%</view>
    </view>
    <view class="plan-progress-track">
      <view class="plan-progress-fill" style="width: {{progressPercent}}%;"></view>
    </view>
    <view class="next-task-text">{{nextTaskText}}</view>
  </view>

  <view class="list-heading">
    <view class="section-heading">每日学习计划</view>
    <view class="week-hint">每周查看更清晰</view>
  </view>

  <scroll-view
    class="week-tabs"
    scroll-x="{{true}}"
    show-scrollbar="{{false}}"
    scroll-with-animation="{{true}}"
    scroll-left="{{weekScrollLeft}}"
  >
    <view class="week-tabs-inner">
      <view
        wx:for="{{weeks}}"
        wx:key="index"
        class="week-tab {{selectedWeekIndex == item.index ? 'is-active' : ''}} {{item.completed ? 'is-complete' : ''}}"
        data-index="{{item.index}}"
        bindtap="selectWeek"
      >
        <view class="week-tab-title">{{item.label}}</view>
        <view class="week-tab-meta">{{item.range}} · {{item.completedCount}}/{{item.total}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="day-list">
    <view
      class="day-card {{item.completed ? 'is-completed' : ''}} {{expandedDay == item.day ? 'is-expanded' : ''}}"
      wx:for="{{visibleItems}}"
      wx:key="day"
    >
      <view class="day-top" data-day="{{item.day}}" bindtap="toggleDayExpand">
        <view class="day-number">{{item.day}}</view>
        <view class="day-main">
          <view class="day-title">第 {{item.day}} 天</view>
          <view class="day-theme">{{item.title}}</view>
          <view class="day-summary">
            <text>{{item.duration}}</text>
            <text class="summary-separator">·</text>
            <text>{{item.taskCount}} 项任务</text>
          </view>
        </view>
        <view
          class="complete-control {{item.completed ? 'is-checked' : ''}}"
          data-index="{{item.originalIndex}}"
          catchtap="toggleComplete"
        >
          <view class="check-circle">{{item.completed ? '✓' : ''}}</view>
          <text>{{item.completed ? '已完成' : '完成'}}</text>
        </view>
      </view>

      <view
        class="day-details-wrap {{expandedDay == item.day ? 'is-open' : ''}}"
        style="height: {{expandedDay == item.day ? item.detailsHeight : 0}}px;"
      >
        <view class="day-details" data-day="{{item.day}}">
          <view class="task-list">
            <view
              class="task-row"
              wx:for="{{item.tasks}}"
              wx:for-item="task"
              wx:for-index="taskIndex"
              wx:key="*this"
            >
              <view class="task-index">
                <text class="task-index-number">{{taskIndex + 1}}</text>
                <text class="task-index-check">✓</text>
              </view>
              <view class="task-text">
                <text class="task-label">{{task}}</text>
              </view>
            </view>
          </view>

          <view class="day-tip">
            <view class="tip-label">今日提醒</view>
            <view class="tip-text">{{item.tip}}</view>
          </view>
        </view>
      </view>

      <view
        class="expand-handle {{expandedDay == item.day ? 'is-open' : ''}}"
        data-day="{{item.day}}"
        bindtap="toggleDayExpand"
      >
        <text>{{expandedDay == item.day ? '收起任务' : '查看今日任务'}}</text>
        <view class="expand-arrow"></view>
      </view>
    </view>
  </view>

  <view class="plan-action-bar">
    <view class="plan-action-inner">
      <button class="utility-action-button" bindtap="handleRegenerate">
        <view class="refresh-action-icon"></view>
        <text class="utility-action-label">重新生成</text>
      </button>

      <button class="utility-action-button" bindtap="openFeedback">
        <view class="feedback-action-icon"></view>
        <text class="utility-action-label">计划反馈</text>
      </button>

      <button class="poster-action-button" bindtap="handlePoster">
        <view class="share-action-icon">
          <view class="share-action-line share-action-line-a"></view>
          <view class="share-action-line share-action-line-b"></view>
          <view class="share-action-node share-action-node-a"></view>
          <view class="share-action-node share-action-node-b"></view>
          <view class="share-action-node share-action-node-c"></view>
        </view>
        <text>生成分享海报</text>
      </button>
    </view>
  </view>

  <view class="completion-celebration" wx:if="{{showPlanCelebration}}">
    <view class="confetti confetti-a"></view>
    <view class="confetti confetti-b"></view>
    <view class="confetti confetti-c"></view>
    <view class="confetti confetti-d"></view>
    <view class="confetti confetti-e"></view>
    <view class="confetti confetti-f"></view>
    <view class="confetti confetti-g"></view>
    <view class="confetti confetti-h"></view>
    <view class="confetti confetti-i"></view>
    <view class="confetti confetti-j"></view>

    <view class="completion-card">
      <view class="completion-icon">
        <view class="completion-check">✓</view>
      </view>
      <view class="completion-kicker">计划全部完成</view>
      <view class="completion-title">这个暑假的坚持，已经开花啦！</view>
      <view class="completion-description">每一次认真完成，都在让你离目标更近一步。</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showFeedback}}" catchtap="closeFeedback">
    <view class="feedback-modal" catchtap="noop">
      <view class="modal-title">这个计划对你有帮助吗？</view>
      <view class="feedback-tags">
        <view
          wx:for="{{feedbackOptions}}"
          wx:key="label"
          class="feedback-tag {{item.active ? 'is-active' : ''}}"
          data-index="{{index}}"
          bindtap="toggleFeedback"
        >{{item.label}}</view>
      </view>
      <textarea
        class="feedback-input"
        placeholder="你希望计划哪里更具体？可以简单说说。"
        value="{{feedbackText}}"
        bindinput="handleFeedbackInput"
        maxlength="200"
      ></textarea>
      <button class="primary-button submit-feedback" bindtap="submitFeedback">提交反馈</button>
    </view>
  </view>
</view>
