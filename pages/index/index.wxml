<view class="page index-page">
  <view class="hero">
    <view class="hero-bg hero-bg-large"></view>
    <view class="hero-bg hero-bg-small"></view>
    <view class="hero-kicker">暑假充电，从现在开始</view>
    <view class="hero-title">
      <view>孩子基础差？</view>
      <view>先生成一份补基础计划</view>
    </view>
    <view class="hero-desc">
      <view>选择年级、科目和学习目标</view>
      <view>1 分钟生成每日学习安排</view>
    </view>
    <view class="hero-tags">
      <view class="hero-tag">1 分钟填写</view>
      <view class="hero-tag">每日任务清单</view>
      <view class="hero-tag">可保存分享</view>
    </view>
    <view class="hero-card-icon">
      <view class="hero-card-line line-a"></view>
      <view class="hero-card-line line-b"></view>
      <view class="hero-card-line line-c"></view>
      <view class="hero-check">✓</view>
    </view>
  </view>

  <view class="form-card">
    <view class="section-heading">填写孩子信息</view>

    <view class="field">
      <view class="field-title">孩子年级</view>
      <view class="option-grid">
        <view
          wx:for="{{gradeOptions}}"
          wx:key="*this"
          class="option {{form.grade == item ? 'is-active' : ''}}"
          data-field="grade"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">薄弱科目</view>
      <view class="option-grid option-grid-three">
        <view
          wx:for="{{subjectOptions}}"
          wx:key="*this"
          class="option {{form.subject == item ? 'is-active' : ''}}"
          data-field="subject"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">当前基础</view>
      <view class="option-grid option-grid-three">
        <view
          wx:for="{{levelOptions}}"
          wx:key="*this"
          class="option {{form.level == item ? 'is-active' : ''}}"
          data-field="level"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">学习目标</view>
      <view class="option-grid">
        <view
          wx:for="{{goalOptions}}"
          wx:key="*this"
          class="option {{form.goal == item ? 'is-active' : ''}}"
          data-field="goal"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">计划天数</view>
      <view class="option-grid option-grid-four">
        <view
          wx:for="{{daysOptions}}"
          wx:key="*this"
          class="option option-compact {{form.days == item ? 'is-active' : ''}}"
          data-field="days"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">每天可学习时间</view>
      <view class="option-grid option-grid-four">
        <view
          wx:for="{{timeOptions}}"
          wx:key="*this"
          class="option option-compact {{form.dailyTime == item ? 'is-active' : ''}}"
          data-field="dailyTime"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-note">生成结果仅作为学习安排参考，家长可根据孩子实际情况调整。</view>

  <view class="fixed-actions">
    <button
      class="primary-button {{isComplete ? '' : 'is-disabled'}}"
      disabled="{{!isComplete}}"
      bindtap="handleGenerate"
    >{{isComplete ? '生成我的暑假学习计划' : '请填写完整信息'}}</button>
  </view>
</view>
