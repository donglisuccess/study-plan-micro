<view class="page index-page">
  <swiper
    class="banner-swiper"
    indicator-dots="{{true}}"
    indicator-color="rgba(7, 24, 50, 0.22)"
    indicator-active-color="#2f80ed"
    autoplay="{{true}}"
    interval="4000"
    duration="500"
    circular="{{true}}"
  >
    <swiper-item wx:for="{{bannerList}}" wx:key="url">
      <view class="banner-slide" style="background: {{item.background}};">
        <image class="banner-image" src="{{item.url}}" mode="aspectFill" />
      </view>
    </swiper-item>
  </swiper>

  <view class="saved-plan-card" wx:if="{{savedPlan}}">
    <view class="saved-plan-card-header">
      <view class="saved-plan-eyebrow">上次学习计划</view>
      <button class="all-plans-button" bindtap="handleViewAllPlans">
        <view class="all-plans-icon"></view>
        <text>全部计划</text>
        <text class="all-plans-count">{{planCount}}</text>
        <text class="all-plans-arrow">›</text>
      </button>
    </view>
    <view class="saved-plan-top">
      <view class="saved-plan-info">
        <view class="saved-plan-title">{{savedPlan.grade}} · {{savedPlan.subject}}</view>
        <view class="saved-plan-meta">{{savedPlan.goal}} · {{savedPlan.days}} 天 · 每天 {{savedPlan.dailyTime}}</view>
      </view>
      <view class="saved-plan-percent">{{savedPlan.progressPercent}}%</view>
    </view>
    <view class="saved-progress-track">
      <view class="saved-progress-fill" style="width: {{savedPlan.progressPercent}}%;"></view>
    </view>
    <view class="saved-plan-bottom">
      <view class="saved-plan-next">{{savedPlan.nextTaskText}}</view>
      <button class="continue-plan-button" bindtap="handleContinuePlan">
        {{savedPlan.allCompleted ? '查看计划' : '继续学习'}}
      </button>
    </view>
  </view>

  <view class="form-card">
    <view class="section-heading">{{savedPlan ? '生成一份新计划' : '填写孩子信息'}}</view>

    <view class="options-status" wx:if="{{isLoadingOptions}}">
      <view class="loading-dot"></view>
      <view>正在加载可选信息...</view>
    </view>

    <view class="options-status is-error" wx:elif="{{optionsLoadFailed}}">
      <view>基本信息加载失败，请确认 Python 后端已启动。</view>
      <button class="retry-options-button" bindtap="retryLoadOptions">重新加载</button>
    </view>

    <block wx:else>
    <view class="field">
      <view class="field-title">孩子年级</view>
      <view class="option-grid option-grid-four-per-row">
        <view
          wx:for="{{gradeOptions}}"
          wx:key="*this"
          class="option {{form.grade == item ? 'is-active' : ''}}"
          data-field="grade"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">薄弱科目</view>
      <view class="option-grid option-grid-four-per-row">
        <view
          wx:for="{{subjectOptions}}"
          wx:key="*this"
          class="option {{form.subject == item ? 'is-active' : ''}}"
          data-field="subject"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">当前基础</view>
      <view class="option-grid option-grid-three">
        <view
          wx:for="{{levelOptions}}"
          wx:key="*this"
          class="option {{form.level == item ? 'is-active' : ''}}"
          data-field="level"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">学习目标</view>
      <view class="option-grid">
        <view
          wx:for="{{goalOptions}}"
          wx:key="*this"
          class="option {{form.goal == item ? 'is-active' : ''}}"
          data-field="goal"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">计划天数</view>
      <view class="option-grid option-grid-four">
        <view
          wx:for="{{daysOptions}}"
          wx:key="*this"
          class="option option-compact {{form.days == item ? 'is-active' : ''}}"
          data-field="days"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-title">每天可学习时间</view>
      <view class="option-grid option-grid-four">
        <view
          wx:for="{{timeOptions}}"
          wx:key="*this"
          class="option option-compact {{form.dailyTime == item ? 'is-active' : ''}}"
          data-field="dailyTime"
          data-value="{{item}}"
          bindtap="selectOption"
        >{{item}}</view>
      </view>
    </view>
    </block>
  </view>

  <view class="index-submit-area">
    <button
      class="index-generate-button {{isComplete && !isLoadingOptions && !optionsLoadFailed ? '' : 'is-disabled'}}"
      disabled="{{!isComplete || isLoadingOptions || optionsLoadFailed}}"
      bindtap="handleGenerate"
    >
      <text>{{isLoadingOptions ? '正在加载选项' : isComplete ? '生成暑假学习计划' : '请填写完整信息'}}</text>
      <text class="generate-arrow" wx:if="{{isComplete && !isLoadingOptions && !optionsLoadFailed}}">→</text>
    </button>
    <view class="bottom-note">
      <text class="note-icon">i</text>
      <text>生成结果仅作为学习安排参考，家长可根据孩子实际情况调整</text>
    </view>
  </view>
</view>
