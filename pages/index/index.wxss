.index-page {
  background: #f3f7fb;
  padding-bottom: calc(230rpx + env(safe-area-inset-bottom));
}

.banner-swiper {
  width: 100%;
  height: 400rpx;
}

.banner-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-image {
  display: block;
  width: 100%;
  height: 100%;
}

.saved-plan-card {
  margin: 20rpx 30rpx 0;
  padding: 26rpx 28rpx;
  border: 2rpx solid #cfe1f6;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(36, 64, 102, 0.07);
}

.saved-plan-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.saved-plan-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.saved-plan-info {
  flex: 1;
  min-width: 0;
}

.saved-plan-eyebrow {
  color: #2f80ed;
  font-size: 23rpx;
  font-weight: 700;
}

.all-plans-button {
  min-width: 194rpx;
  height: 64rpx;
  padding: 0 14rpx;
  border: 2rpx solid #d7e7f8;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9rpx;
  background: #f7fbff;
  color: #36516f;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 800;
}

.all-plans-icon {
  position: relative;
  width: 25rpx;
  height: 29rpx;
  border: 3rpx solid #2f80ed;
  border-radius: 4rpx;
}

.all-plans-icon::before,
.all-plans-icon::after {
  content: '';
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: #2f80ed;
}

.all-plans-icon::before {
  top: 7rpx;
}

.all-plans-icon::after {
  top: 15rpx;
}

.all-plans-count {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 7rpx;
  border-radius: 9rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e2f0ff;
  color: #1f66bf;
  font-size: 20rpx;
  line-height: 1;
}

.all-plans-arrow {
  color: #2f80ed;
  font-size: 30rpx;
  line-height: 1;
}

.saved-plan-title {
  margin-top: 4rpx;
  color: #071832;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 900;
}

.saved-plan-meta {
  margin-top: 6rpx;
  overflow: hidden;
  color: #718198;
  font-size: 23rpx;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.saved-plan-percent {
  flex: 0 0 auto;
  color: #269d6a;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 900;
}

.saved-progress-track {
  height: 12rpx;
  margin-top: 20rpx;
  overflow: hidden;
  border-radius: 99rpx;
  background: #e4edf7;
}

.saved-progress-fill {
  height: 100%;
  border-radius: 99rpx;
  background: linear-gradient(90deg, #2f80ed 0%, #37b982 100%);
}

.saved-plan-bottom {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.saved-plan-next {
  flex: 1;
  min-width: 0;
  color: #42546b;
  font-size: 24rpx;
  line-height: 1.45;
}

.continue-plan-button {
  flex: 0 0 164rpx;
  width: 164rpx;
  height: 68rpx;
  border-radius: 14rpx;
  background: #2f80ed;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 68rpx;
  font-weight: 800;
}

.form-card {
  margin: 20rpx 30rpx 0;
  padding: 32rpx 30rpx 26rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(36, 64, 102, 0.08);
  position: relative;
  z-index: 2;
}

.field {
  padding-top: 28rpx;
  border-top: 1rpx solid #e8eef6;
}

.options-status {
  min-height: 220rpx;
  padding: 40rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #708199;
  text-align: center;
}

.options-status.is-error {
  flex-direction: column;
  color: #8b4a26;
}

.loading-dot {
  width: 24rpx;
  height: 24rpx;
  border: 6rpx solid #cfe2f8;
  border-top-color: #2f80ed;
  border-radius: 50%;
  animation: options-loading 0.8s linear infinite;
}

.retry-options-button {
  min-width: 180rpx;
  height: 68rpx;
  margin-top: 12rpx;
  border: 2rpx solid #2f80ed;
  border-radius: 16rpx;
  color: #1f66bf;
  font-size: 27rpx;
  line-height: 68rpx;
  background: #ffffff;
}

@keyframes options-loading {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.field + .field {
  margin-top: 28rpx;
}

.field-title {
  margin-bottom: 20rpx;
  color: #071832;
  font-size: 31rpx;
  font-weight: 700;
}

.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.option-grid-four-per-row .option {
  flex: 0 0 calc((100% - 54rpx) / 4);
  min-width: 0;
  padding-left: 8rpx;
  padding-right: 8rpx;
}

.option {
  min-width: 154rpx;
  min-height: 78rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #dbe4ef;
  border-radius: 18rpx;
  background: #ffffff;
  color: #1a2b43;
  font-size: 29rpx;
  font-weight: 500;
}

.option-compact {
  min-width: 138rpx;
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.option.is-active {
  color: #1f66bf;
  border-color: #2f80ed;
  background: #eaf4ff;
  box-shadow: 0 0 0 6rpx rgba(47, 128, 237, 0.1);
  font-weight: 800;
}

.index-submit-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 22rpx 0 calc(10rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e6edf6;
  box-shadow: 0 -12rpx 32rpx rgba(7, 24, 50, 0.08);
}

.index-generate-button {
  width: 80% !important;
  height: 96rpx;
  margin: 0 auto;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(105deg, #2f80ed 0%, #2164b9 100%);
  color: #ffffff;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  box-shadow: 0 14rpx 28rpx rgba(34, 103, 190, 0.22);
}

.index-generate-button.is-disabled {
  background: #cbd9ec;
  color: #91a8c4;
  box-shadow: none;
}

.index-generate-button[disabled] {
  opacity: 1;
}

.generate-arrow {
  margin-top: 2rpx;
  font-size: 34rpx;
  font-weight: 500;
}

.bottom-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 90%;
  margin: 16rpx auto 0;
  color: #708199;
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
}

.note-icon {
  flex: 0 0 26rpx;
  width: 26rpx;
  height: 26rpx;
  border: 2rpx solid #8293aa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8293aa;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 700;
}

@media screen and (max-width: 350px) {
  .option-grid-four-per-row .option {
    font-size: 26rpx;
  }
}
