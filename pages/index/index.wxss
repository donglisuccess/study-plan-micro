.index-page {
  background: #f3f7fb;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 420rpx;
  padding: 58rpx 40rpx 42rpx;
  background: linear-gradient(135deg, #2f80ed 0%, #1f62b5 100%);
  color: #ffffff;
}

.hero-bg {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
}

.hero-bg-large {
  width: 270rpx;
  height: 270rpx;
  right: -70rpx;
  top: -42rpx;
}

.hero-bg-small {
  width: 150rpx;
  height: 150rpx;
  right: 72rpx;
  bottom: -50rpx;
}

.hero-kicker {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  color: #d9eaff;
  margin-bottom: 18rpx;
}

.hero-title {
  position: relative;
  z-index: 1;
  max-width: 500rpx;
  font-size: 48rpx;
  line-height: 1.22;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-desc {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  font-size: 29rpx;
  line-height: 1.6;
  color: #eaf3ff;
}

.hero-tags {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
}

.hero-tag {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.17);
  color: #ffffff;
  font-size: 25rpx;
}

.hero-card-icon {
  position: absolute;
  right: 74rpx;
  bottom: 110rpx;
  width: 82rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.25);
}

.hero-card-line {
  position: absolute;
  left: 12rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.55);
}

.line-a {
  top: 18rpx;
  width: 56rpx;
}

.line-b {
  top: 38rpx;
  width: 44rpx;
}

.line-c {
  top: 58rpx;
  width: 32rpx;
}

.hero-check {
  position: absolute;
  right: -34rpx;
  top: -24rpx;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff8243;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.form-card {
  margin: -26rpx 30rpx 0;
  padding: 32rpx 30rpx 26rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(36, 64, 102, 0.08);
  position: relative;
  z-index: 2;
}

.field {
  padding-top: 28rpx;
  border-top: 1rpx solid #e8eef6;
}

.field + .field {
  margin-top: 28rpx;
}

.field-title {
  margin-bottom: 20rpx;
  color: #071832;
  font-size: 31rpx;
  font-weight: 700;
}

.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.option {
  min-width: 154rpx;
  min-height: 78rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #dbe4ef;
  border-radius: 18rpx;
  background: #ffffff;
  color: #1a2b43;
  font-size: 29rpx;
  font-weight: 500;
}

.option-compact {
  min-width: 138rpx;
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.option.is-active {
  color: #1f66bf;
  border-color: #2f80ed;
  background: #eaf4ff;
  box-shadow: 0 0 0 6rpx rgba(47, 128, 237, 0.1);
  font-weight: 800;
}

.bottom-note {
  display: flex;
  align-items: center;
  margin: 22rpx 32rpx 0;
  color: #708199;
  font-size: 24rpx;
}
