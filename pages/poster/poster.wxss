.poster-page {
  padding: 28rpx 28rpx calc(148rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 50% 0, rgba(58, 120, 242, 0.08), transparent 31%),
    #f5f6f8;
}

.preview-heading {
  margin: 0 0 22rpx;
  text-align: center;
}

.preview-title {
  color: #333333;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 600;
}

.preview-subtitle {
  margin-top: 7rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.5;
}

.poster-preview {
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 64rpx rgba(35, 57, 86, 0.12);
}

.poster-cover {
  position: relative;
  overflow: hidden;
  min-height: 536rpx;
  padding: 36rpx 38rpx 40rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #2f6fe4 0%, #4d91f5 72%, #66a6f5 100%);
}

.cover-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.cover-glow-a {
  right: -150rpx;
  top: -176rpx;
  width: 450rpx;
  height: 450rpx;
  border: 58rpx solid rgba(255, 255, 255, 0.08);
}

.cover-glow-b {
  left: -128rpx;
  bottom: -220rpx;
  width: 390rpx;
  height: 390rpx;
  background: rgba(21, 72, 166, 0.12);
}

.cover-grid {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 190rpx;
  opacity: 0.15;
  background:
    linear-gradient(rgba(255, 255, 255, 0.28) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.28) 1rpx, transparent 1rpx);
  background-size: 32rpx 32rpx;
}

.brand-row {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.brand-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  line-height: 1;
  font-weight: 500;
}

.brand-symbol {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 9rpx;
}

.symbol-line {
  position: absolute;
  left: 7rpx;
  right: 7rpx;
  height: 3rpx;
  border-radius: 99rpx;
  background: #ffffff;
}

.symbol-line-a {
  top: 9rpx;
}

.symbol-line-b {
  top: 19rpx;
}

.subject-tag {
  max-width: 180rpx;
  padding: 10rpx 17rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.13);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cover-content {
  position: relative;
  z-index: 2;
  margin-top: 61rpx;
}

.cover-eyebrow {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(18, 64, 146, 0.2);
  color: #dfeeff;
  font-size: 21rpx;
  line-height: 1;
  letter-spacing: 2rpx;
}

.cover-title {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  color: #ffffff;
  font-size: 48rpx;
  line-height: 1.28;
  font-weight: 600;
  letter-spacing: 1rpx;
  text-shadow: 0 5rpx 18rpx rgba(29, 78, 160, 0.18);
}

.cover-description {
  max-width: 510rpx;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  line-height: 1.65;
}

.duration-panel {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 24rpx;
  width: 350rpx;
  margin-top: 40rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.14);
}

.duration-main {
  flex: 0 0 auto;
  display: flex;
  align-items: flex-end;
  color: #ffffff;
}

.duration-number {
  font-size: 52rpx;
  line-height: 0.95;
  font-weight: 600;
}

.duration-unit {
  margin: 0 0 5rpx 7rpx;
  font-size: 22rpx;
  line-height: 1;
}

.duration-copy {
  padding-left: 22rpx;
  border-left: 1rpx solid rgba(255, 255, 255, 0.28);
}

.duration-label {
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
  line-height: 1.3;
}

.duration-text {
  margin-top: 5rpx;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 500;
}

.poster-content {
  padding: 34rpx 36rpx 33rpx;
}

.goal-card {
  position: relative;
  min-height: 128rpx;
  padding: 25rpx 78rpx 25rpx 30rpx;
  overflow: hidden;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #f3f7ff;
}

.goal-marker {
  flex: 0 0 9rpx;
  width: 9rpx;
  height: 58rpx;
  border-radius: 99rpx;
  background: #3a78f2;
}

.goal-main {
  flex: 1;
  min-width: 0;
}

.content-label {
  color: #8b97a5;
  font-size: 21rpx;
  line-height: 1.35;
  letter-spacing: 1rpx;
}

.goal-value {
  margin-top: 6rpx;
  color: #293b52;
  font-size: 31rpx;
  line-height: 1.4;
  font-weight: 600;
}

.goal-stamp {
  position: absolute;
  right: -18rpx;
  top: 24rpx;
  width: 88rpx;
  height: 88rpx;
  border: 3rpx solid rgba(58, 120, 242, 0.12);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(58, 120, 242, 0.23);
  font-size: 22rpx;
  font-weight: 600;
  transform: rotate(13deg);
}

.profile-row {
  display: flex;
  align-items: stretch;
  margin: 30rpx 0;
  padding: 3rpx 0;
}

.profile-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.profile-divider {
  flex: 0 0 1rpx;
  width: 1rpx;
  margin: 3rpx 0;
  background: #e8ebef;
}

.profile-label {
  color: #999999;
  font-size: 21rpx;
  line-height: 1.3;
}

.profile-value {
  margin-top: 7rpx;
  padding: 0 8rpx;
  overflow: hidden;
  color: #333333;
  font-size: 26rpx;
  line-height: 1.35;
  font-weight: 500;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.focus-card {
  padding: 27rpx 28rpx 28rpx;
  border: 1rpx solid #ebedf0;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(35, 57, 86, 0.05);
}

.focus-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.focus-title {
  margin-top: 7rpx;
  color: #333333;
  font-size: 29rpx;
  line-height: 1.45;
  font-weight: 600;
}

.focus-index {
  flex: 0 0 auto;
  color: #e0e7f2;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 600;
}

.focus-text {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef0f3;
  color: #5d6875;
  font-size: 26rpx;
  line-height: 1.78;
}

.promise-row {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  margin-top: 27rpx;
  padding: 0 5rpx;
}

.promise-mark {
  flex: 0 0 auto;
  margin-top: -8rpx;
  color: #3a78f2;
  font-family: Georgia, serif;
  font-size: 52rpx;
  line-height: 1;
  opacity: 0.32;
}

.promise-text {
  flex: 1;
  color: #747f8c;
  font-size: 24rpx;
  line-height: 1.65;
}

.poster-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
  padding-top: 26rpx;
  border-top: 1rpx dashed #dfe3e8;
}

.footer-brand {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 13rpx;
}

.footer-logo {
  flex: 0 0 52rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #3a78f2;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
}

.footer-title {
  color: #3f4b59;
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 500;
}

.footer-subtitle {
  margin-top: 3rpx;
  color: #a0a7af;
  font-size: 18rpx;
  line-height: 1.4;
}

.footer-badge {
  flex: 0 0 auto;
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  background: #f0f4fa;
  color: #7d8997;
  font-size: 19rpx;
  line-height: 1;
}

.poster-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 18rpx;
  color: #999999;
  font-size: 23rpx;
  line-height: 1.4;
}

.hint-line {
  width: 30rpx;
  height: 1rpx;
  background: #d8dde3;
}

.poster-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 14rpx 22rpx calc(14rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e4ebf4;
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(7, 24, 50, 0.07);
  transform: translate3d(0, 0, 0);
  backface-visibility: hidden;
}

.poster-action-inner {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
}

.utility-action-button {
  flex: 0 0 112rpx;
  width: 112rpx;
  height: 92rpx;
  border: 2rpx solid #e0e7f0;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #f8fafc;
  color: #666666;
}

.utility-action-button[disabled] {
  color: #8b96a4;
  opacity: 0.72;
}

.utility-action-label {
  font-size: 21rpx;
  line-height: 1;
  font-weight: 700;
}

.share-main-button {
  flex: 1;
  min-width: 0;
  height: 92rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: #3a78f2;
  color: #ffffff;
  font-size: 29rpx;
  line-height: 1.2;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(58, 120, 242, 0.18);
}

.share-icon {
  flex: 0 0 34rpx;
  position: relative;
  width: 34rpx;
  height: 34rpx;
}

.share-dot {
  position: absolute;
  z-index: 2;
  width: 11rpx;
  height: 11rpx;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  background: #3a78f2;
}

.share-dot-a {
  left: 0;
  top: 12rpx;
}

.share-dot-b {
  right: 0;
  top: 0;
}

.share-dot-c {
  right: 0;
  bottom: 0;
}

.share-link {
  position: absolute;
  z-index: 1;
  left: 8rpx;
  width: 22rpx;
  height: 3rpx;
  border-radius: 99rpx;
  background: #ffffff;
  transform-origin: left center;
}

.share-link-a {
  top: 14rpx;
  transform: rotate(-28deg);
}

.share-link-b {
  top: 19rpx;
  transform: rotate(28deg);
}

.save-action-icon {
  position: relative;
  width: 34rpx;
  height: 32rpx;
}

.save-arrow {
  position: absolute;
  left: 14rpx;
  top: 0;
  width: 6rpx;
  height: 19rpx;
  border-radius: 4rpx;
  background: #63758c;
}

.save-arrow::after {
  content: "";
  position: absolute;
  left: -6rpx;
  bottom: -1rpx;
  width: 12rpx;
  height: 12rpx;
  border-right: 5rpx solid #63758c;
  border-bottom: 5rpx solid #63758c;
  transform: rotate(45deg);
}

.save-tray {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  bottom: 0;
  height: 10rpx;
  border: 4rpx solid #63758c;
  border-top: none;
  border-radius: 0 0 5rpx 5rpx;
}

.save-action-icon.is-saving {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid #d8e0ea;
  border-top-color: #3a78f2;
  border-radius: 50%;
  animation: poster-saving 0.8s linear infinite;
}

.save-action-icon.is-saving .save-arrow,
.save-action-icon.is-saving .save-tray {
  display: none;
}

.back-action-icon {
  position: relative;
  width: 31rpx;
  height: 31rpx;
  border: 4rpx solid #63758c;
  border-radius: 50%;
}

.back-action-icon::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 7rpx;
  width: 9rpx;
  height: 9rpx;
  border-left: 4rpx solid #63758c;
  border-bottom: 4rpx solid #63758c;
  transform: rotate(45deg);
}

.back-action-icon::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 13rpx;
  width: 14rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #63758c;
}

.poster-canvas {
  position: fixed;
  left: -10000px;
  top: 0;
  pointer-events: none;
}

@keyframes poster-saving {
  to {
    transform: rotate(360deg);
  }
}

@media screen and (max-width: 350px) {
  .poster-page {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }

  .poster-cover {
    padding-left: 31rpx;
    padding-right: 31rpx;
  }

  .cover-title {
    font-size: 44rpx;
  }

  .poster-content {
    padding-left: 30rpx;
    padding-right: 30rpx;
  }
}
