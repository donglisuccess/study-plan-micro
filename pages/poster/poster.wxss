.poster-page {
  padding: 38rpx 30rpx calc(220rpx + env(safe-area-inset-bottom));
  background: #f3f7fb;
}

.poster-note {
  margin: 4rpx 0 34rpx;
  text-align: center;
  color: #72829a;
  font-size: 27rpx;
}

.poster-preview {
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 56rpx rgba(36, 64, 102, 0.1);
}

.poster-head {
  position: relative;
  overflow: hidden;
  min-height: 330rpx;
  padding: 76rpx 42rpx 46rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ed 0%, #1e4f96 100%);
}

.poster-bg {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.poster-bg-a {
  width: 220rpx;
  height: 220rpx;
  right: -20rpx;
  top: -46rpx;
}

.poster-bg-b {
  width: 160rpx;
  height: 160rpx;
  left: 36rpx;
  bottom: -80rpx;
}

.poster-brand,
.poster-title,
.poster-subtitle {
  position: relative;
  z-index: 1;
}

.poster-brand {
  font-size: 27rpx;
  color: #cfe4ff;
}

.poster-title {
  margin-top: 28rpx;
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 900;
}

.poster-subtitle {
  margin-top: 16rpx;
  font-size: 29rpx;
  color: #e5f1ff;
}

.poster-body {
  padding: 44rpx 40rpx 42rpx;
}

.poster-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.poster-info-card {
  min-height: 166rpx;
  padding: 24rpx 18rpx;
  border-radius: 20rpx;
  background: #f3f7fb;
  text-align: center;
}

.poster-icon {
  width: 44rpx;
  height: 44rpx;
  margin: 0 auto 12rpx;
  border-radius: 50%;
  position: relative;
}

.target-icon {
  border: 8rpx solid #ff8243;
}

.target-icon::after {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2f80ed;
}

.clock-icon {
  border: 6rpx solid #ff8243;
}

.clock-icon::before,
.clock-icon::after {
  content: "";
  position: absolute;
  left: 19rpx;
  top: 10rpx;
  width: 5rpx;
  height: 15rpx;
  border-radius: 999rpx;
  background: #071832;
}

.clock-icon::after {
  top: 21rpx;
  transform: rotate(55deg);
  transform-origin: top;
}

.calendar-icon {
  border-radius: 8rpx;
  border: 5rpx solid #ff8243;
}

.calendar-icon::before {
  content: "";
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 12rpx;
  height: 5rpx;
  background: #2f80ed;
}

.book-icon {
  border-radius: 8rpx;
  background: #2f80ed;
  box-shadow: 12rpx 0 0 #ffcf6b, 24rpx 0 0 #39b67a;
  width: 22rpx;
}

.poster-label {
  color: #72829a;
  font-size: 24rpx;
}

.poster-value {
  margin-top: 6rpx;
  color: #071832;
  font-size: 29rpx;
  line-height: 1.25;
  font-weight: 900;
}

.focus-block {
  margin-top: 34rpx;
}

.focus-title {
  color: #071832;
  font-size: 30rpx;
  font-weight: 900;
}

.focus-text {
  margin-top: 12rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #fff8f2;
  color: #7a421d;
  font-size: 28rpx;
  line-height: 1.6;
}

.poster-slogan {
  margin-top: 34rpx;
  text-align: center;
  color: #1f66bf;
  font-size: 31rpx;
  font-weight: 900;
}

.qr-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 34rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #e8eef6;
}

.qr-placeholder {
  position: relative;
  flex: 0 0 116rpx;
  width: 116rpx;
  height: 116rpx;
  border: 8rpx solid #071832;
  border-radius: 12rpx;
  background: #ffffff;
}

.qr-dot {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: #071832;
}

.dot-a {
  left: 18rpx;
  top: 18rpx;
}

.dot-b {
  right: 18rpx;
  top: 18rpx;
}

.dot-c {
  left: 18rpx;
  bottom: 18rpx;
}

.dot-d {
  right: 22rpx;
  bottom: 28rpx;
}

.qr-text {
  flex: 1;
  color: #42546b;
  font-size: 28rpx;
  font-weight: 700;
}

.poster-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.poster-action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.share-button {
  color: #1f66bf;
  border-color: #2f80ed;
}
