.generating-page {
  padding: 120rpx 54rpx 80rpx;
  background: #f3f7fb;
  text-align: center;
}

.loading-visual {
  display: flex;
  justify-content: center;
  margin: 42rpx 0 72rpx;
}

.paper {
  position: relative;
  width: 270rpx;
  height: 270rpx;
  border-radius: 42rpx;
  background: linear-gradient(145deg, #2f80ed 0%, #1e63b8 100%);
  box-shadow: 0 28rpx 70rpx rgba(47, 128, 237, 0.24);
}

.paper-line {
  position: absolute;
  left: 50rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
}

.paper-line-long {
  top: 88rpx;
  width: 170rpx;
}

.paper-line-mid {
  top: 118rpx;
  width: 118rpx;
}

.paper-line-longer {
  top: 148rpx;
  width: 146rpx;
}

.paper-line-short {
  top: 178rpx;
  width: 104rpx;
}

.paper-ring {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.56);
  border-bottom-color: #ff8243;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.main-title {
  font-size: 40rpx;
  line-height: 1.35;
  color: #071832;
  font-weight: 900;
}

.sub-title {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #73839b;
}

.progress-track {
  height: 12rpx;
  margin: 66rpx 36rpx 52rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #dce8f5;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2f80ed 0%, #ff8243 100%);
  transition: width 0.25s ease;
}

.step-card,
.fail-card {
  padding: 28rpx 36rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 50rpx rgba(36, 64, 102, 0.08);
  text-align: left;
}

.step-row {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  color: #c2ccda;
  font-size: 29rpx;
  border-bottom: 1rpx solid #eef3f8;
}

.step-row:last-child {
  border-bottom: none;
}

.step-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #f0f5fb;
  color: #2f80ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.step-row.is-done {
  color: #73839b;
}

.step-row.is-done .step-icon {
  background: #eaf4ff;
}

.step-row.is-active {
  color: #071832;
  font-weight: 800;
}

.step-row.is-active .step-icon {
  border: 8rpx solid #2f80ed;
  background: #ffffff;
}

.fail-card {
  text-align: center;
}

.fail-title {
  margin: 20rpx 0 32rpx;
  color: #071832;
  font-size: 32rpx;
  font-weight: 800;
}

.retry-button {
  height: 88rpx;
}
