page {
  min-height: 100%;
  background: #f3f7fb;
  color: #071832;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  line-height: inherit;
  font-size: inherit;
  text-align: center;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
}

.section-heading {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 28rpx 0 22rpx;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #071832;
}

.section-heading::before {
  content: "";
  width: 8rpx;
  height: 34rpx;
  border-radius: 12rpx;
  background: #2f80ed;
}

.primary-button {
  width: 100%;
  height: 96rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #2f80ed 0%, #1f66bf 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(47, 128, 237, 0.24);
}

.primary-button.is-disabled {
  background: #c8d7ea;
  color: #8fa4bf;
  box-shadow: none;
}

.outline-button {
  height: 88rpx;
  border: 3rpx solid #d6e0ee;
  border-radius: 20rpx;
  color: #42546b;
  font-size: 30rpx;
  font-weight: 600;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.outline-button.is-warm {
  border-color: #ffcfad;
  color: #e96d2d;
}

.fixed-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #e8eef6;
  box-shadow: 0 -10rpx 30rpx rgba(7, 24, 50, 0.08);
}

.muted {
  color: #72829a;
}
